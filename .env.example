# ================================
# APPLICATION
# ================================
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=InboxIQ

# ================================
# MONGODB
# ================================
MONGO_URI=mongodb://mongo:27017/inboxiq
MONGO_TEST_URI=mongodb://localhost:27017/inboxiq_test

# ================================
# REDIS
# ================================
REDIS_URL=redis://redis:6379

# ================================
# JWT
# ================================
JWT_ACCESS_SECRET=change_this_to_a_very_long_and_secure_random_secret_key_access
JWT_REFRESH_SECRET=change_this_to_a_very_long_and_secure_random_secret_key_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# CLOUDINARY
# ================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================
# EMAIL / SMTP (v2 — placeholder)
# ================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=noreply@inboxiq.app

# ================================
# SECURITY
# ================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ================================
# AI (v2 — placeholder)
# ================================
OPENAI_API_KEY=your_openai_key

# ================================
# CLIENT
# ================================
CLIENT_URL=http://localhost:3000
